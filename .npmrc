# Supply-chain hardening for pnpm
# 7-day soak (10080 minutes) before installing any newly-published version
minimum-release-age=10080

# Refuse to install if the lockfile is out of sync (CI safety)
prefer-frozen-lockfile=true

# `pnpm add` writes exact versions (caret/tilde ranges in publish-time
# dependencies are still acceptable for libraries — this controls
# what `pnpm add` writes by default, not what's already in package.json)
save-exact=true

# `pnpm audit` fails on moderate+ vulnerabilities
audit-level=moderate
