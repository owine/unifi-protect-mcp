{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommits",
    ":semanticPrefixFixDepsChoreOthers"
  ],
  "timezone": "America/Chicago",
  "schedule": [
    "on monday"
  ],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "lockFileMaintenance": {
    "automerge": true
  },
  "packageRules": [
    {
      "groupName": "eslint",
      "matchPackageNames": [
        "eslint",
        "@eslint/js",
        "typescript-eslint"
      ]
    },
    {
      "groupName": "vitest",
      "matchPackageNames": [
        "vitest",
        "@vitest/*"
      ]
    },
    {
      "groupName": "type definitions",
      "matchPackageNames": [
        "@types/*"
      ]
    },
    {
      "description": "Automerge dev tooling (non-compiler)",
      "matchDepTypes": [
        "devDependencies"
      ],
      "automerge": true,
      "matchPackageNames": [
        "!typescript"
      ]
    },
    {
      "description": "MCP SDK — always review",
      "matchPackageNames": [
        "@modelcontextprotocol/sdk"
      ],
      "automerge": false
    },
    {
      "description": "Never automerge major bumps",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "description": "Pin and group Node.js versions in CI",
      "groupName": "node versions",
      "matchManagers": [
        "nodenv",
        "nvm"
      ],
      "automerge": true
    },
    {
      "description": "Pin and group GitHub Actions runner images",
      "groupName": "github runners",
      "matchManagers": [
        "github-actions"
      ],
      "matchDepTypes": [
        "github-runner"
      ],
      "automerge": true
    }
  ]
}
