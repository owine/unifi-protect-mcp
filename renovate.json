{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommits"
  ],
  "semanticCommitType": "deps",
  "semanticCommitScope": null,
  "timezone": "America/Chicago",
  "schedule": [
    "on monday"
  ],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "lockFileMaintenance": {
    "automerge": true,
    "schedule": [
      "on monday"
    ]
  },
  "packageRules": [
    {
      "description": "Batch non-major dev dependency bumps into one PR",
      "groupName": "dev dependencies",
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ]
    },
    {
      "groupName": "eslint",
      "matchPackageNames": [
        "eslint",
        "@eslint/js",
        "typescript-eslint"
      ]
    },
    {
      "groupName": "vitest",
      "matchPackageNames": [
        "vitest",
        "@vitest/*"
      ]
    },
    {
      "groupName": "type definitions",
      "matchPackageNames": [
        "@types/*"
      ]
    },
    {
      "description": "Automerge dev tooling (non-compiler)",
      "matchDepTypes": [
        "devDependencies"
      ],
      "automerge": true,
      "matchPackageNames": [
        "!typescript"
      ]
    },
    {
      "description": "MCP SDK — always review",
      "matchPackageNames": [
        "@modelcontextprotocol/sdk"
      ],
      "automerge": false
    },
    {
      "description": "Never automerge major bumps",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "description": "Pin and group Node.js versions in CI",
      "groupName": "node versions",
      "matchDatasources": [
        "node-version"
      ],
      "automerge": true
    },
    {
      "description": "Pin and group GitHub Actions runner images",
      "groupName": "github runners",
      "matchDatasources": [
        "github-runners"
      ],
      "automerge": true
    },
    {
      "description": "Group GitHub Actions digest/version updates",
      "groupName": "github actions",
      "matchManagers": [
        "github-actions"
      ],
      "automerge": true
    },
    {
      "description": "Group non-MCP production deps (patch/minor)",
      "groupName": "production dependencies",
      "matchDepTypes": [
        "dependencies"
      ],
      "matchPackageNames": [
        "!@modelcontextprotocol/sdk"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ]
    },
    {
      "description": "Group TypeScript with its type definitions",
      "groupName": "typescript toolchain",
      "matchPackageNames": [
        "typescript",
        "@types/node"
      ]
    }
  ]
}
