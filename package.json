{
  "name": "@owine/unifi-protect-mcp",
  "version": "2.4.0",
  "description": "MCP server for UniFi Protect Integration API",
  "main": "dist/index.js",
  "bin": {
    "unifi-protect-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "engines": {
    "node": "v26.1.0"
  },
  "packageManager": "pnpm@11.1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/owine/unifi-protect-mcp.git"
  },
  "keywords": [
    "unifi",
    "protect",
    "mcp",
    "model-context-protocol",
    "ubiquiti"
  ],
  "author": "owine",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "ws": "8.20.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.12.4",
    "@types/ws": "8.18.1",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vitest": "4.1.5"
  }
}
